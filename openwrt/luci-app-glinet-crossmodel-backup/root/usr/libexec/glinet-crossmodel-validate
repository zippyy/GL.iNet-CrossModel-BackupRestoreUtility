#!/bin/sh
# Read-only compatibility and safety preflight for portable profiles.
# Usage: glinet-crossmodel-validate <profile.tar.gz> <categories-csv>

set -eu
PATH='/usr/sbin:/usr/bin:/sbin:/bin'

log() { printf '%s\n' "$*"; }
die() { log "ERROR: $*" >&2; exit 1; }

has_category() {
	case ",$1," in *",$2,"*) return 0 ;; *) return 1 ;; esac
}

json_escape() {
	printf '%s' "$1" | tr '\r\n' '  ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_field() {
	# Profiles generated by this utility use compact JSON without embedded quotes
	# in model/firmware fields.
	grep -o '"'"$2"'":"[^"]*"' "$1" 2>/dev/null | head -n1 | sed 's/^[^:]*:"//;s/"$//' || true
}

count_config() {
	local file kind
	file="$1"; kind="$2"
	[ -f "$file" ] || { printf '0\n'; return; }
	grep -c "^config $kind " "$file" 2>/dev/null || true
}

file_present() {
	[ -s "$1" ]
}

add() {
	printf '%s\n' "$2" >> "$1"
}

json_list() {
	local file first item
	file="$1"; first=1
	printf '['
	while IFS= read -r item || [ -n "$item" ]; do
		[ -n "$item" ] || continue
		[ "$first" -eq 1 ] || printf ','
		first=0
		printf '"%s"' "$(json_escape "$item")"
	done < "$file"
	printf ']'
}

target_zone_names() {
	local section
	uci -q show firewall 2>/dev/null | sed -n 's/^firewall\.\([^=]*\)=zone$/\1/p' | while IFS= read -r section; do
		uci -q get "firewall.$section.name" 2>/dev/null || true
	done
}

usage() {
	echo 'Usage: glinet-crossmodel-validate <profile.tar.gz> <categories-csv>' >&2
	exit 2
}

[ "$#" -eq 2 ] || usage
archive="$1"
categories="$2"
[ -f "$archive" ] || die 'Profile archive is missing.'

tar -tzf "$archive" >/dev/null 2>&1 || die 'Profile archive cannot be read.'
work="$(mktemp -d /tmp/glinet-crossmodel-validate.XXXXXX)"
trap 'rm -rf "$work"' EXIT INT TERM

tar -C "$work" -xzf "$archive"
profile="$work/profile"
[ -f "$profile/meta.json" ] || die 'Profile archive does not contain metadata.'

will="$work/will"
warn="$work/warn"
skip="$work/skip"
: > "$will"; : > "$warn"; : > "$skip"

source_model="$(json_field "$profile/meta.json" model)"
source_arch="$(json_field "$profile/meta.json" architecture)"
source_firmware="$(json_field "$profile/meta.json" firmware)"
target_model="$(cat /tmp/sysinfo/model 2>/dev/null || true)"
target_board="$(cat /tmp/sysinfo/board_name 2>/dev/null || true)"
target_arch="$(uname -m 2>/dev/null || printf unknown)"
target_firmware="$(ubus call system board 2>/dev/null | jsonfilter -e '@.release.version' 2>/dev/null || true)"
[ -n "$target_model" ] || target_model="$target_board"
[ -n "$target_model" ] || target_model='OpenWrt router'
[ -n "$source_model" ] || source_model='Portable profile source'

source_network="$profile/uci/network"
source_dhcp="$profile/uci/dhcp"
source_wireless="$profile/uci/wireless"
source_firewall="$profile/uci/firewall"
source_wireguard="$profile/uci/wireguard"
source_openvpn="$profile/uci/openvpn"
source_adguard="$profile/uci/adguardhome"
source_ddns="$profile/uci/ddns"

if has_category "$categories" network; then
	interfaces="$(count_config "$source_network" interface)"
	dhcp_entries="$(count_config "$source_dhcp" dhcp)"
	if [ "$interfaces" -gt 0 ] 2>/dev/null; then
		add "$will" "Network & WAN: $interfaces portable interface setting(s) and $dhcp_entries DHCP setting(s) are available for review and import."
		add "$warn" 'Network settings are applied last. A changed LAN/WAN address can end the SSH session; reconnect using the new address afterward.'
	else
		add "$skip" 'Network & WAN: no portable network configuration was found in this profile.'
	fi
fi

if has_category "$categories" wireless; then
	source_ssids="$(count_config "$source_wireless" wifi-iface)"
	target_radios="$(uci -q show wireless 2>/dev/null | grep -c '=wifi-device' || true)"
	if [ "$source_ssids" -eq 0 ] 2>/dev/null; then
		add "$skip" 'Wireless: no wireless profiles were found in this archive.'
	elif [ "$target_radios" -eq 0 ] 2>/dev/null; then
		add "$skip" "Wireless: $source_ssids profile(s) found, but no target radio configuration was detected."
	else
		add "$will" "Wireless: $source_ssids profile(s) can be applied against $target_radios detected target radio(s)."
		add "$warn" 'Wireless changes may disconnect clients. On a remote restore, reload is deferred until the target is rebooted.'
	fi
fi

if has_category "$categories" vpn; then
	vpn_count=0
	file_present "$source_wireguard" && vpn_count=$((vpn_count + 1))
	file_present "$source_openvpn" && vpn_count=$((vpn_count + 1))
	if [ "$vpn_count" -gt 0 ]; then add "$will" "VPN: $vpn_count portable WireGuard/OpenVPN configuration group(s) detected."; else add "$skip" 'VPN: no WireGuard or OpenVPN configuration was found.'; fi
fi

if has_category "$categories" firewall; then
	rules="$(count_config "$source_firewall" rule)"
	redirects="$(count_config "$source_firewall" redirect)"
	if [ "$rules" -gt 0 ] 2>/dev/null || [ "$redirects" -gt 0 ] 2>/dev/null; then
		missing=''
		zones="$(target_zone_names | tr '\n' ' ')"
		for zone in $(sed -n "s/^[[:space:]]*option \(src\|dest\) '\([^']*\)'$/\2/p" "$source_firewall" 2>/dev/null | sort -u); do
			case " $zones " in *" $zone "*) ;; *) missing="${missing:+$missing, }$zone" ;; esac
		done
		if [ -n "$missing" ]; then
			add "$skip" "Firewall: $rules rule(s) and $redirects port-forward(s) reference target-missing zone(s): $missing. Deselect Firewall until those zones are mapped."
		else
			add "$will" "Firewall: $rules portable rule(s) and $redirects port-forward(s) match the target's known zone names."
		fi
	else
		add "$skip" 'Firewall: no named rules or port forwards were found.'
	fi
fi

if has_category "$categories" adguard; then
	if file_present "$source_adguard" && uci -q show adguardhome >/dev/null 2>&1; then add "$will" 'AdGuard Home: matching target configuration exists.'; elif file_present "$source_adguard"; then add "$skip" 'AdGuard Home: source configuration exists but the target has no matching adguardhome UCI config.'; else add "$skip" 'AdGuard Home: no source configuration was found.'; fi
fi

if has_category "$categories" ddns; then
	if file_present "$source_ddns"; then add "$will" 'Dynamic DNS: portable provider configuration is present.'; else add "$skip" 'Dynamic DNS: no source configuration was found.'; fi
fi

if has_category "$categories" system; then
	add "$skip" 'System settings: reference only. Hardware-specific system values are never imported automatically.'
fi

if has_category "$categories" packages; then
	if [ -s "$profile/packages/manifest.txt" ]; then
		package_count="$(wc -l < "$profile/packages/manifest.txt" | tr -d ' ')"
		add "$warn" "Packages: $package_count manifest entry/entries will only be resolved from the target's configured feeds when package installation is explicitly enabled. Core and kmod packages are skipped."
	else
		add "$skip" 'Packages: no installed-package manifest was found.'
	fi
fi

if has_category "$categories" scripts; then
	if [ -s "$profile/artifacts/scripts.tar.gz" ]; then add "$warn" 'Custom scripts/files: staged safely under /root/glinet-crossmodel-restore by default. Direct overwrite requires explicit approval.'; else add "$skip" 'Custom scripts/files: no artifact archive was found.'; fi
fi

if has_category "$categories" binaries; then
	if [ ! -s "$profile/artifacts/binaries.tar.gz" ]; then
		add "$skip" 'Custom ELF binaries: no artifact archive was found.'
	elif [ -z "$source_arch" ] || [ "$source_arch" != "$target_arch" ]; then
		add "$skip" "Custom ELF binaries: blocked because source architecture ${source_arch:-unknown} does not match target $target_arch."
	else
		add "$will" "Custom ELF binaries: source and target architecture both report $target_arch."
	fi
fi

printf '{"source":{"model":"%s","architecture":"%s","firmware":"%s"},' "$(json_escape "$source_model")" "$(json_escape "$source_arch")" "$(json_escape "$source_firmware")"
printf '"target":{"model":"%s","architecture":"%s","firmware":"%s"},' "$(json_escape "$target_model")" "$(json_escape "$target_arch")" "$(json_escape "$target_firmware")"
printf '"will_apply":'; json_list "$will"; printf ',"warnings":'; json_list "$warn"; printf ',"skipped":'; json_list "$skip"; printf '}\n'
